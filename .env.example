# Copy to .env and fill in values. Never commit .env.
# Variable names match pydantic-settings defaults (UPPER_SNAKE from field names).

# App
# DEBUG=false

# Supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Bucket must exist in Supabase Storage (default name below).
# SUPABASE_STORAGE_BUCKET=cv-uploads

# Auth / API
# API_SECRET_KEY=

# Anthropic — required for the 6-agent CV pipeline
# ANTHROPIC_API_KEY=

# CORS — comma-separated frontend origins (default * for local dev)
# CORS_ORIGINS=*
